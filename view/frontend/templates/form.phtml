<script>
document.addEventListener('DOMContentLoaded', function () {
    var tabs = document.querySelectorAll('.pyn-track-tab');
    var panels = document.querySelectorAll('.pyn-track-panel');

    function activateTab(targetId) {
        tabs.forEach(function (tab) {
            var active = tab.getAttribute('data-tab-target') === targetId;
            tab.classList.toggle('is-active', active);
            tab.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        panels.forEach(function (panel) {
            panel.classList.toggle('is-active', panel.id === targetId);
        });
    }

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            activateTab(tab.getAttribute('data-tab-target'));
        });
    });

    var alertBox = document.getElementById('pyn-track-alert');
    if (alertBox) {
        setTimeout(function () {
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 120);
    }
});
</script>
