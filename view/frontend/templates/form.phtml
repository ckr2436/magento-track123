<?php
/** @var \Magento\Framework\View\Element\Template $block */
$request = $block->getRequest();

$formValues = (array)$block->getData('form_values');
$lookupError = (string)$block->getData('lookup_error');
$lookupChallenge = $block->getData('lookup_challenge');
$hasChallenge = is_array($lookupChallenge) && !empty($lookupChallenge);

$queryMode = (string)($formValues['query_mode'] ?? $request->getParam('query_mode', 'order'));
if (!in_array($queryMode, ['order', 'tracking'], true)) {
    $queryMode = 'order';
}

$incrementId = (string)($formValues['increment_id'] ?? '');
$emailOrPhone = (string)($formValues['email_or_phone'] ?? '');
$trackingNumber = (string)($formValues['tracking_number'] ?? '');

$verificationPostalCode = (string)($formValues['verification_postal_code'] ?? '');
$verificationPhoneSuffix = (string)($formValues['verification_phone_suffix'] ?? '');

$requiresPostalCode = $hasChallenge && (bool)($lookupChallenge['requires_postal_code'] ?? false);
$requiresPhoneSuffix = $hasChallenge && (bool)($lookupChallenge['requires_phone_suffix'] ?? false);
$challengeTitle = $hasChallenge ? (string)($lookupChallenge['title'] ?? '') : '';
$challengeMessage = $hasChallenge ? (string)($lookupChallenge['message'] ?? '') : '';

$alertTitle = '';
$alertBody = '';

if ($lookupError !== '') {
    if ($queryMode === 'tracking') {
        $alertTitle = (string)__('Tracking number not found');
        $alertBody = (string)__('We could not find that tracking number in shipments created by this store. Please check the number and try again.');
    } else {
        $alertTitle = (string)__('Order details not found');
        $alertBody = (string)__('We could not match that order number with the email address or phone number provided. Please check your details and try again.');
    }
}

$actionUrl = $block->getUrl('track-order/lookup');
?>

