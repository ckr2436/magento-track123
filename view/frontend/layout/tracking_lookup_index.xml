<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      layout="1column">
    <head>
        <css src="Pynarae_Tracking::css/tracking.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceBlock name="breadcrumbs" remove="true"/>

        <referenceContainer name="content">
            <block class="Pynarae\Tracking\Block\Form"
                   name="pynarae.tracking.form"
                   template="Pynarae_Tracking::form.phtml"/>
            <block class="Pynarae\Tracking\Block\Result"
                   name="pynarae.tracking.result"
                   template="Pynarae_Tracking::result.phtml"
                   after="pynarae.tracking.form"/>
        </referenceContainer>
    </body>
</page>
