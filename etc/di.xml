<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Pynarae\Tracking\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">pynarae_tracking</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Pynarae\Tracking\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

    <preference for="Pynarae\Tracking\Api\Provider\ProviderResolverInterface"
                type="Pynarae\Tracking\Model\Provider\ProviderResolver"/>

    <type name="Pynarae\Tracking\Model\Provider\ProviderPool">
        <arguments>
            <argument name="providers" xsi:type="array">
                <item name="track123" xsi:type="object">Pynarae\Tracking\Model\Provider\Track123\Track123Provider</item>
                <item name="ship24" xsi:type="object">Pynarae\Tracking\Model\Provider\Ship24\Ship24Provider</item>
            </argument>
        </arguments>
    </type>
</config>
