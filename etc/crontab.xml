<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="pynarae_tracking_process_queue"
             instance="Pynarae\Tracking\Cron\ProcessQueue"
             method="execute">
            <schedule>* * * * *</schedule>
        </job>
        <job name="pynarae_tracking_cleanup"
             instance="Pynarae\Tracking\Cron\Cleanup"
             method="execute">
            <schedule>17 3 * * *</schedule>
        </job>
    </group>
</config>
